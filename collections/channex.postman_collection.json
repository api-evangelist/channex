        },
        {
          "name": "Delete rate plan",
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{baseUrl}}/rate_plans/:id", "host": ["{{baseUrl}}"], "path": ["rate_plans", ":id"], "variable": [ { "key": "id", "value": "" } ] } }
        }
