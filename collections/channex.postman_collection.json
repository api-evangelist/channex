          "name": "Delete room type",
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{baseUrl}}/room_types/:id", "host": ["{{baseUrl}}"], "path": ["room_types", ":id"], "variable": [ { "key": "id", "value": "" } ] } }
        }
