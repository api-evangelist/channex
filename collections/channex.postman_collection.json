            "body": { "mode": "raw", "raw": "{\n  \"values\": [\n    {\n      \"property_id\": \"\",\n      \"room_type_id\": \"\",\n      \"date\": \"\",\n      \"availability\": 0\n    }\n  ]\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/availability", "host": ["{{baseUrl}}"], "path": ["availability"] }
